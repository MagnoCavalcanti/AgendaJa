# =====================================================================
# VARIÁVEIS DE AMBIENTE (copie para um arquivo ".env.local" e preencha)
# Nunca suba o .env.local para o Git. No deploy da Vercel, cadastre
# essas mesmas chaves em Settings > Environment Variables.
# =====================================================================

# String de conexão do MongoDB Atlas (Database > Connect > Drivers).
# Troque <usuario>, <senha> e <cluster> pelos seus dados.
MONGODB_URI="mongodb+srv://<usuario>:<senha>@<cluster>.mongodb.net/agendaja?retryWrites=true&w=majority"

# Segredo usado pelo NextAuth para assinar os tokens JWT da sessão.
# Gere um valor forte com: openssl rand -base64 32
NEXTAUTH_SECRET="cole-aqui-um-segredo-bem-aleatorio"

# URL pública da aplicação. Em desenvolvimento use localhost;
# em produção, a URL da Vercel (ex: https://agendaja.vercel.app).
NEXTAUTH_URL="http://localhost:3000"
